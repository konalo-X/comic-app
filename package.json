{
  "name": "comic-app",
  "version": "1.0.0",
  "description": "Electron + Vue 3 comic reader application",
  "main": "electron/main.js",
  "author": "Comic App",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron . --no-sandbox",
    "build": "vite build && electron-builder",
    "build:web": "vite build",
    "start": "electron .",
    "lint": "eslint src/ --fix",
    "lint:check": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "adm-zip": "^0.5.18",
    "archiver": "^8.0.0",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0-rc.12",
    "dompurify": "^3.4.11",
    "nedb-promises": "^6.2.3",
    "pinia": "^3.0.4",
    "sharp": "^0.35.3",
    "sql.js": "^1.14.1",
    "uuid": "^14.0.1",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.comic.app",
    "productName": "ComicApp",
    "files": [
      "electron/**/*",
      "!electron/_test_match*.js",
      "!electron/*.bak*",
      "!electron/*.sqljs_backup",
      "dist/**/*",
      "build/icons/**/*",
      "package.json",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/color/**/*",
      "node_modules/detect-libc/**/*",
      "node_modules/semver/**/*",
      "node_modules/b4a/**/*",
      "node_modules/string_decoder/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage"
      ]
    }
  },
  "optionalDependencies": {
    "@img/sharp-darwin-arm64": "^0.35.3",
    "@img/sharp-libvips-darwin-arm64": "^1.3.2"
  }
}
